{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(*.env)",
      "Bash(* .env *)",
      "Read(./app-config.yaml)",
      "Read(./sensitive/**)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(bat:*)",
      "Bash(xxd:*)",
      "Bash(strings:*)",
      "Bash(od:*)"
    ],
    "ask": [
      "Read(./restricted/**)"
    ],
    "allow": [
      "Read(./public/**)",
      "Read(./README.md)",
      "Read(./.claude/settings.json)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(grep -l:*)",
      "Bash(grep -r -l:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env.*",
        "**/.env",
        "**/.env.*",
        "./app-config.yaml",
        "./sensitive/**"
      ]
    }
  }
}
