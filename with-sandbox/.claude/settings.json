{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(*.env)",
      "Bash(* .env *)",
      "Read(./app-config.yaml)",
      "Read(./sensitive/**)"
    ],
    "ask": [
      "Read(./restricted/**)",
      "Bash(*)"
    ],
    "allow": [
      "Read(./public/**)",
      "Read(./README.md)",
      "Read(./.claude/settings.json)",
      "Bash(ls:*)",
      "Bash(tree:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env.*",
        "**/.env",
        "**/.env.*",
        "./app-config.yaml",
        "./sensitive/**"
      ]
    },
    "excludedCommands": [
      "ls",
      "ls *",
      "tree",
      "tree *"
    ]
  }
}
