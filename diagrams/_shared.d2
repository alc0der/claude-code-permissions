classes: {
  code-step: {
    shape: step
    style.font: mono
  }
  prompt-bubble: {
    shape: callout
    style.font-size: 28
  }
  target-file: {
    shape: page
  }
  deny-edge: {
    style.stroke: "#cc0000"
  }
  muted-edge: {
    style.stroke: "#cccccc"
  }
  flow-edge: {
    style.animated: true
  }
  header-outline: {
    style.stroke-width: 4
  }
  title-callout: {
    shape: callout
    style.font-size: 28
    style.animated: true
    style.stroke-width: 4
  }
}
