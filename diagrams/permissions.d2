direction: right

u: User {
  shape: person
}

claude: Claude

permissions: permissions {
  shape: step
}

sandbox: sandbox {
  shape: step
}

file: file {
  shape: document
}

u -> claude: "prompt" {
  style.animated: true
}
claude -> permissions: "tool call" {
  style.animated: true
}
permissions -> sandbox: "passes" {
  style.animated: true
}
sandbox -> file: "opens" {
  style.animated: true
}

scenarios: {
  1-deny-env: {
    title: |md
      # Scenario 1 — `.env` denied at the permissions layer
    | {
      near: top-center
      shape: text
    }

    file: ".env"

    permissions.rules: |`json
      "deny": [
        "Read(./.env)",
        "Bash(*.env)",
        "Bash(* .env *)"
      ]
    `|

    sandbox.off: |md
      *(no sandbox)*
    |
    sandbox.style.opacity: 0.35

    aside: |md
      **Blind spot:**
      `python3 -c '...open(".env")...'`
      slips pattern matching;
      falls to ask. → see 1b.
    | {
      shape: text
    }

    (u -> claude)[0]: "Read the .env file and tell me what's in it."
    (claude -> permissions)[0]: "Read(./.env)"
    (permissions -> sandbox)[0]: "✗ Read(./.env) deny" {
      style.stroke: "#cc0000"
    }
    (sandbox -> file)[0]: "not reached" {
      style.stroke: "#cccccc"
      style.animated: false
    }
    direction: right
  }

  1b-sandbox-blocks-bypass: {
    direction: right
    title: |md
      # Scenario 1b — OS sandbox catches what permissions miss
    | {
      near: top-center
      shape: text
    }

    file: ".env"

    permissions.rules: |`json
      "deny": [
        "Read(./.env)",
        "Bash(*.env)",
        "Bash(* .env *)"
      ]
    `|

    sandbox.rules: |`json
      "sandbox": {
        "enabled": true,
        "filesystem": {
          "denyRead": [
            "./.env",
            "**/.env"
          ]
        }
      }
    `|

    aside: |md
      `python3 -c '...'` isn't
      matched by any deny rule.
      Sandbox intercepts
      `open(".env")` at the
      syscall → `EACCES`.
    | {
      shape: text
    }

    (u -> claude)[0]: "Run: python3 -c 'print(open(\".env\").read())'"
    (claude -> permissions)[0]: "Bash: python3 -c ..."
    (permissions -> sandbox)[0]: "✓ no match → passes"
    (sandbox -> file)[0]: "✗ EACCES" {
      style.stroke: "#cc0000"
    }
  }

  2-deny-innocuous: {
    direction: right
    title: |md
      # Scenario 2 — `app-config.yaml` denied the same way
    | {
      near: top-center
      shape: text
    }

    file: "app-config.yaml"

    permissions.rules: |`json
      "deny": [
        "Read(./app-config.yaml)"
      ]
    `|

    sandbox.off: |md
      *(no sandbox)*
    |
    sandbox.style.opacity: 0.35

    (u -> claude)[0]: "Read app-config.yaml and tell me which port the app runs on."
    (claude -> permissions)[0]: "Read(./app-config.yaml)"
    (permissions -> sandbox)[0]: "✗ matches deny" {
      style.stroke: "#cc0000"
    }
    (sandbox -> file)[0]: "not reached" {
      style.stroke: "#cccccc"
      style.animated: false
    }
  }

  3-sensitive-list-only: {
    direction: right
    title: |md
      # Scenario 3 — `sensitive/**` listable, not readable
    | {
      near: top-center
      shape: text
    }

    file: "sensitive/customer-data.csv"

    permissions.rules: |`json
      "deny":  ["Read(./sensitive/**)"],
      "allow": [
        "Bash(ls:*)",
        "Bash(find:*)",
        "Bash(grep -l:*)",
        "Bash(wc:*)"
      ]
    `|

    sandbox.off: |md
      *(no sandbox)*
    |
    sandbox.style.opacity: 0.35

    (u -> claude)[0]: "List files under sensitive/ and count lines in each."
    (claude -> permissions)[0]: "Bash: ls sensitive/"
    (permissions -> sandbox)[0]: "✓ matches allow"
    (sandbox -> file)[0]: "✓ names + sizes"
  }

  4-restricted-ask: {
    direction: right
    title: |md
      # Scenario 4 — `restricted/**` requires your OK
    | {
      near: top-center
      shape: text
    }

    file: "restricted/team-notes.md"

    permissions.rules: |`json
      "ask": [
        "Read(./restricted/**)"
      ]
    `|

    sandbox.off: |md
      *(no sandbox)*
    |
    sandbox.style.opacity: 0.35

    (u -> claude)[0]: "Summarize restricted/team-notes.md"
    (claude -> permissions)[0]: "Read(./restricted/team-notes.md)"
    (permissions -> sandbox)[0]: "? awaits approval" {
      style.stroke: "#cc9900"
    }
    (sandbox -> file)[0]: "if approved: ✓ reads"

    permissions -> u: "prompts: allow?" {
      style.animated: true
      style.stroke: "#cc9900"
    }
  }
}
