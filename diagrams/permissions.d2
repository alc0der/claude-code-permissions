direction: right

u: User {
  shape: person
}

claude: Claude

permissions: permissions {
  shape: step
}

sandbox: sandbox {
  shape: step
}

file: file {
  shape: document
}

u -> claude: "prompt" {
  style.animated: true
}
claude -> permissions: "tool call" {
  style.animated: true
}
permissions -> sandbox: "passes" {
  style.animated: true
}
sandbox -> file: "opens" {
  style.animated: true
}

scenarios: {
  1-deny-env: {
    title: |md
      # Scenario 1 — `.env` denied at the permissions layer
    | {
      near: top-center
      shape: text
    }

    file: ".env"

    permissions.rules: |`json
      "deny": [
        "Read(./.env)",
        "Bash(*.env)",
        "Bash(* .env *)"
      ]
    `|

    sandbox.off: |md
      *(no sandbox)*
    |
    sandbox.style.opacity: 0.35

    aside: |md
      **Blind spot:**
      `python3 -c '...open(".env")...'`
      slips pattern matching;
      falls to ask. → see 1b.
    | {
      shape: text
    }

    (u -> claude)[0]: "Read the .env file and tell me what's in it."
    (claude -> permissions)[0]: "Read(./.env)"
    (permissions -> sandbox)[0]: "✗ Read(./.env) deny" {
      style.stroke: "#cc0000"
    }
    (sandbox -> file)[0]: "not reached" {
      style.stroke: "#cccccc"
      style.animated: false
    }
    direction: right
  }

  1b-sandbox-blocks-bypass: {
    direction: right
    title: |md
      # Scenario 1b — OS sandbox catches what permissions miss
    | {
      near: top-center
      shape: text
    }

    file: ".env"

    permissions.rules: |`json
      "deny": [
        "Read(./.env)",
        "Bash(*.env)",
        "Bash(* .env *)"
      ]
    `|

    sandbox.rules: |`json
      "sandbox": {
        "enabled": true,
        "filesystem": {
          "denyRead": [
            "./.env",
            "**/.env"
          ]
        }
      }
    `|

    aside: |md
      `python3 -c '...'` isn't
      matched by any deny rule.
      Sandbox intercepts
      `open(".env")` at the
      syscall → `EACCES`.
    | {
      shape: text
    }

    (u -> claude)[0]: "Run: python3 -c 'print(open(\".env\").read())'"
    (claude -> permissions)[0]: "Bash: python3 -c ..."
    (permissions -> sandbox)[0]: "✓ no match → passes"
    (sandbox -> file)[0]: "✗ EACCES" {
      style.stroke: "#cc0000"
    }
  }

  2-deny-innocuous: {
    direction: right
    title: |md
      # Scenario 2 — sandbox backstops `app-config.yaml` (same slip, no name bias)
    | {
      near: top-center
      shape: text
    }

    file: "app-config.yaml"

    permissions.rules: |`json
      "deny": [
        "Read(./app-config.yaml)",
        "Bash(cat:*)",
        "Bash(head:*)"
      ]
    `|

    sandbox.rules: |`json
      "sandbox": {
        "enabled": true,
        "filesystem": {
          "denyRead": [
            "./app-config.yaml"
          ]
        }
      }
    `|

    aside: |md
      `python3 -c '...'` slips
      the permission filter for
      `app-config.yaml` just like
      it did for `.env` — sandbox
      catches it by path at the
      `open()` syscall.
    | {
      shape: text
    }

    (u -> claude)[0]: "Run: python3 -c 'print(open(\"app-config.yaml\").read())'"
    (claude -> permissions)[0]: "Bash: python3 -c ..."
    (permissions -> sandbox)[0]: "✓ no match → passes"
    (sandbox -> file)[0]: "✗ EACCES" {
      style.stroke: "#cc0000"
    }
  }

  3-sensitive-list-only: {
    direction: right
    title: |md
      # Scenario 3 — `sensitive/**` listable, not readable
    | {
      near: top-center
      shape: text
    }

    file: "sensitive/customer-data.csv"

    permissions.rules: |`json
      "deny":  ["Read(./sensitive/**)"],
      "allow": [
        "Bash(ls:*)",
        "Bash(tree:*)"
      ],
      "ask":   ["Bash(*)"]
    `|

    sandbox.rules: |`json
      "sandbox": {
        "enabled": true,
        "filesystem": {
          "denyRead": ["./sensitive/**"]
        },
        "excludedCommands": [
          "ls", "ls *",
          "tree", "tree *"
        ]
      }
    `|

    aside: |md
      `ls`/`tree` are whitelisted
      via `excludedCommands` —
      they run **outside** the
      sandbox, so `readdir` works.
      A `cat`/`python3 -c` bypass
      would be **asked**; even if
      you approve, the subprocess
      runs **inside** the sandbox
      and hits `EACCES` on `open()`.
    | {
      shape: text
    }

    (u -> claude)[0]: "List files under sensitive/."
    (claude -> permissions)[0]: "Bash: ls sensitive/"
    (permissions -> sandbox)[0]: "✓ allow → excluded"
    (sandbox -> file)[0]: "✓ names only"
  }

  4-restricted-ask: {
    direction: right
    title: |md
      # Scenario 4 — `restricted/**` requires your OK
    | {
      near: top-center
      shape: text
    }

    file: "restricted/team-notes.md"

    permissions.rules: |`json
      "ask": [
        "Read(./restricted/**)"
      ]
    `|

    sandbox.off: |md
      *(no sandbox)*
    |
    sandbox.style.opacity: 0.35

    (u -> claude)[0]: "Summarize restricted/team-notes.md"
    (claude -> permissions)[0]: "Read(./restricted/team-notes.md)"
    (permissions -> sandbox)[0]: "? awaits approval" {
      style.stroke: "#cc9900"
    }
    (sandbox -> file)[0]: "if approved: ✓ reads"

    permissions -> u: "prompts: allow?" {
      style.animated: true
      style.stroke: "#cc9900"
    }
  }

  5-nested-inherits: {
    direction: right
    title: |md
      # Scenario 5 — running `claude` from a nested subdir skips the parent's `.claude/`
    | {
      near: top-center
      shape: text
    }

    file: "nested/.env"

    permissions.rules: |`md
      **CWD:** `with-sandbox/nested/`

      No `.claude/` here. Claude
      picks a single project scope
      per session — it does **not**
      walk up merging every
      enclosing `.claude/` it finds.

      The parent's rules:

      ```json
      "deny": ["Read(**/.env)", ...]
      ```

      …never load. Nothing protects
      `.env` here.
    `|

    sandbox.rules: |`md
      Sandbox config lives in the
      same settings file — so the
      OS-level `denyRead` wall also
      isn't active from `nested/`.
      Both defenses vanish together.
    `|

    aside: |md
      Gotcha: rules at
      `with-sandbox/.claude/` cover
      `with-sandbox/` but **not**
      `with-sandbox/nested/`.

      Fix: put `.claude/settings.json`
      in every dir you run Claude
      from, or run Claude from the
      dir that holds the rules. Run
      `/status` to verify what loaded.
    | {
      shape: text
    }

    (u -> claude)[0]: "Read .env (from with-sandbox/nested/)"
    (claude -> permissions)[0]: "Read(./.env)"
    (permissions -> sandbox)[0]: "✓ no rule loaded → passes" {
      style.stroke: "#cc9900"
    }
    (sandbox -> file)[0]: "✓ reads (secret leaks)" {
      style.stroke: "#cc9900"
    }
  }
}
