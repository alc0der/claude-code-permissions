grid-columns: 3

...@../_shared
...@../_scenario-base

title: |md
  # Scenario 5: running claude from a nested subdir skips the parent's .claude/
| {
  near: top-center
  shape: text
}

prompt: "Read .env\nplease" {
  tooltip: "cd with-sandbox/nested && claude"
}
file: "nested/.env"

gate: running claude from a nested subdir skips the parent's .claude/ {
  style.opacity: 0.2

  perm.rules: |`json
    "deny": [
      "Read(./.env)",
      "Read(**/.env)"
    ]
  `|
  perm.style.opacity: 0.2
  perm.rules.style.opacity: 0.2

  sand.rules: |`json
    "sandbox": {
      "enabled": true,
      "filesystem": {
        "denyRead": ["**/.env"]
      }
    }
  `|
  sand.style.opacity: 0.2
  sand.rules.style.opacity: 0.2

  perm -> sand: { style.opacity: 0.2 }
}

prompt -> file: "Read(./.env), reads (secret leaks)" {
  class: flow-edge
  style.stroke: "#cc9900"
}
