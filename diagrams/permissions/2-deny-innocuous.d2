grid-columns: 3

...@../_shared
...@../_scenario-base

title: |md
  # Scenario 2: sandbox backstops app-config.yaml (same slip, no name bias)
| {
  near: top-center
  shape: text
}

prompt: "Run: python3 -c\n'print(open(\"app-config.yaml\").read())'"
file: "app-config.yaml"

gate: sandbox backstops app-config.yaml (same slip, no name bias) {
  perm.rules: |`json
    "deny": [
      "Read(./app-config.yaml)",
      "Bash(cat:*)",
      "Bash(head:*)"
    ]
  `|

  sand.rules: |`json
    "sandbox": {
      "enabled": true,
      "filesystem": {
        "denyRead": [
          "./app-config.yaml"
        ]
      }
    }
  `|

  perm -> sand
}

prompt -> gate.perm: "Bash: python3 -c ..." { class: flow-edge }
gate.sand -> file: "✗ EACCES" { class: deny-edge }
