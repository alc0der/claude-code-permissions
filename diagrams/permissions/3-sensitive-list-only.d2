grid-columns: 3

...@../_shared
...@../_scenario-base

title: |md
  # Scenario 3: sensitive/** listable, not readable
| {
  near: top-center
  shape: text
}

prompt: "List files\nunder sensitive/."
file: "sensitive/customer-data.csv"

gate: sensitive/** listable, not readable {
  perm.rules: |`json
    "deny":  ["Read(./sensitive/**)"],
    "allow": [
      "Bash(ls:*)",
      "Bash(tree:*)"
    ],
    "ask":   ["Bash(*)"]
  `|

  sand.rules: |`json
    "sandbox": {
      "enabled": true,
      "filesystem": {
        "denyRead": ["./sensitive/**"]
      },
      "excludedCommands": [
        "ls", "ls *",
        "tree", "tree *"
      ]
    }
  `|

  perm -> sand
}

prompt -> gate.perm: "Bash: ls sensitive/" { class: flow-edge }
gate.sand -> file: "✓ names only" { class: flow-edge }
