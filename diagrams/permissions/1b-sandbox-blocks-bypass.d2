grid-columns: 3

...@../_shared
...@../_scenario-base

title: |md
  # Scenario 1b: OS sandbox catches what permissions miss
| {
  near: top-center
  shape: text
}

prompt: "Run: python3 -c\n'print(open(\".env\").read())'"
file: ".env"

gate: OS sandbox catches what permissions miss {
  perm.rules: |`json
    "deny": [
      "Read(./.env)",
      "Bash(*.env)",
      "Bash(* .env *)"
    ]
  `|

  sand.rules: |`json
    "sandbox": {
      "enabled": true,
      "filesystem": {
        "denyRead": [
          "./.env",
          "**/.env"
        ]
      }
    }
  `|

  perm -> sand
}

prompt -> gate.perm: "Bash: python3 -c ..." { class: flow-edge }
gate.sand -> file: "✗ EACCES" { class: deny-edge }
